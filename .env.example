# pred.gg OAuth2 — copy this file to .env and fill in your values
# Register your application at https://pred.saibotu.de and add the credentials below.

PRED_GG_APP_ID=
PRED_GG_CLIENT_ID=
PRED_GG_CLIENT_SECRET=
# Token endpoint client auth. "auto" uses Basic auth when PRED_GG_CLIENT_SECRET is present,
# which matches pred.gg confidential apps; use "none" only for public PKCE clients.
PRED_GG_CLIENT_AUTH_METHOD=auto
# Legacy override: sends client_secret in the form body. pred.gg currently rejects this
# for the registered app captured in the HARs, so keep it disabled unless retesting.
PRED_GG_SEND_CLIENT_SECRET=false

# Callback URL must match exactly what's registered in pred.saibotu.de
PRED_GG_CALLBACK_URL=http://localhost:3001/auth/callback
PRED_GG_GQL_URL=https://pred.gg/gql

# OAuth endpoints/scopes. Start at the pred.gg SPA route; it adds the session token
# before calling /api/oauth2/authorize. The backend also adds PKCE automatically.
PRED_GG_AUTHORIZE_URL=https://pred.gg/oauth2/authorize
PRED_GG_TOKEN_URL=https://pred.gg/api/oauth2/token
PRED_GG_TOKEN_URL_FALLBACK=https://pred.saibotu.de/api/oauth2/token
PRED_GG_OAUTH_SCOPES=offline_access profile player:read:interval hero_leaderboard:read matchup_statistic:read

# Frontend URL (used by API for CORS and post-login redirects)
FRONTEND_URL=http://localhost:5173

# PostgreSQL — data-sync worker
DATABASE_URL="postgresql://predecessor:predecessor@localhost:5432/predecessor_build"

# Auth notes (see docs/predecessor_api_technical_doc.md §2.1):
# - Public game data (heroes, items, patches) is accessible without auth.
# - Player search/stats require OAuth2 login via pred.gg.
# - OAuth2 flow: GET /auth/predgg -> pred.gg authorize page -> GET /auth/callback -> token cookie.
# - Token is stored in HTTP-only cookie and sent automatically with API requests.
