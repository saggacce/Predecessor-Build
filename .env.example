# pred.gg OAuth2 — copy this file to .env and fill in your values
# Run the createApplication mutation (see docs/predecessor_api_technical_doc.md §13.6)
# to obtain CLIENT_ID and CLIENT_SECRET for your own registered application.

PRED_GG_APP_ID=
PRED_GG_CLIENT_ID=
PRED_GG_CLIENT_SECRET=

PRED_GG_CALLBACK_URL=http://localhost:3000/auth/callback
PRED_GG_GQL_URL=https://pred.gg/gql

# Auth notes (see docs/predecessor_api_technical_doc.md §2.1):
# - Public game data (heroes, items, matches) is accessible without auth.
# - Send PRED_GG_CLIENT_SECRET as X-Api-Key header for production (rate limits).
# - The authorize mutation requires an active user session — not usable from scripts.
