# pred.gg Application credentials
# Crear la aplicacion en: https://pred.gg (settings > applications)
PREDGG_APP_ID=HiDUme4
PREDGG_CLIENT_ID=l5vdyvqawgovh2qptnumwrsb11ufanyf

# El clientSecret se envía como X-Api-Key header.
# Datos públicos (heroes, items) son accesibles sin auth.
# El X-Api-Key probablemente eleva rate limits o desbloquea endpoints adicionales.
PREDGG_CLIENT_SECRET=<tu_client_secret>

# Nota: el mutation `authorize` requiere sesión de usuario activa (flujo OAuth2
# interactivo). No es usable para acceso máquina-a-máquina desde scripts.
