# pred.gg OAuth2 — copy this file to .env and fill in your values
# Register your application at https://pred.saibotu.de and add the credentials below.

PRED_GG_APP_ID=
PRED_GG_CLIENT_ID=
PRED_GG_CLIENT_SECRET=

# Callback URL must match exactly what's registered in pred.saibotu.de
PRED_GG_CALLBACK_URL=http://localhost:3001/auth/callback
PRED_GG_GQL_URL=https://pred.gg/gql

# Frontend URL (used by API for CORS and post-login redirects)
FRONTEND_URL=http://localhost:5173

# PostgreSQL — data-sync worker
DATABASE_URL="postgresql://predecessor:predecessor@localhost:5432/predecessor_build"

# Auth notes (see docs/predecessor_api_technical_doc.md §2.1):
# - Public game data (heroes, items, patches) is accessible without auth.
# - Player search/stats require OAuth2 login via pred.gg.
# - OAuth2 flow: GET /auth/predgg -> pred.gg authorize page -> GET /auth/callback -> token cookie.
# - Token is stored in HTTP-only cookie and sent automatically with API requests.
