generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Version {
  id          String   @id @default(cuid())
  predggId    String   @unique
  name        String
  releaseDate DateTime
  patchType   String
  syncedAt    DateTime

  matches   Match[]
  snapshots PlayerSnapshot[]
}

model Player {
  id             String   @id @default(cuid())
  predggId       String   @unique
  predggUuid     String   @unique
  displayName    String
  isPrivate      Boolean  @default(false)
  isConsole      Boolean  @default(false)
  inferredRegion String?
  firstSeen      DateTime @default(now())
  lastSynced     DateTime

  customName    String?

  snapshots     PlayerSnapshot[]
  matchPlayers  MatchPlayer[]
  rosterEntries TeamRoster[]
}

model PlayerSnapshot {
  id           String   @id @default(cuid())
  playerId     String
  player       Player   @relation(fields: [playerId], references: [id])
  versionId    String?
  version      Version? @relation(fields: [versionId], references: [id])
  syncedAt     DateTime
  generalStats Json
  heroStats    Json
  roleStats    Json
  rankLabel    String?
  ratingPoints Int?
}

model Team {
  id           String   @id @default(cuid())
  name         String
  abbreviation String?
  logoUrl      String?
  type         TeamType
  region       String?
  notes        String?
  createdAt    DateTime @default(now())

  roster      TeamRoster[]
  memberships TeamMembership[]
}

enum TeamType {
  OWN
  RIVAL
}

model TeamRoster {
  id         String    @id @default(cuid())
  teamId     String
  team       Team      @relation(fields: [teamId], references: [id])
  playerId   String
  player     Player    @relation(fields: [playerId], references: [id])
  role       String?
  activeFrom DateTime  @default(now())
  activeTo   DateTime?
}

model Match {
  id          String   @id @default(cuid())
  predggUuid  String   @unique
  startTime   DateTime
  duration    Int
  gameMode    String
  region      String?
  winningTeam String?
  versionId   String?
  version     Version? @relation(fields: [versionId], references: [id])
  syncedAt           DateTime
  rosterSynced       Boolean  @default(false)
  eventStreamSynced  Boolean  @default(false)

  matchPlayers        MatchPlayer[]
  heroKills           HeroKill[]
  objectiveKills      ObjectiveKill[]
  structureDestructions StructureDestruction[]
  wardEvents          WardEvent[]
  transactions        Transaction[]
  heroBans            HeroBan[]
}

model MatchPlayer {
  id              String  @id @default(cuid())
  matchId         String
  match           Match   @relation(fields: [matchId], references: [id])
  playerId        String?
  player          Player? @relation(fields: [playerId], references: [id])
  predggPlayerUuid String?
  playerName      String
  team           String
  role           String?
  heroSlug       String
  kills          Int
  deaths         Int
  assists        Int
  heroDamage     Int?
  totalDamage    Int?
  gold           Int?
  wardsPlaced    Int?
  wardsDestroyed Int?
  level          Int?
  inventoryItems Json
  perkSlug       String?
  abilityOrder   Json?

  // Gold timeline (event stream — Bearer required)
  goldEarnedAtInterval         Json?

  // Extended stats (populated on resync via match detail query)
  physicalDamageDealtToHeroes  Int?
  magicalDamageDealtToHeroes   Int?
  trueDamageDealtToHeroes      Int?
  heroDamageTaken              Int?
  totalDamageTaken             Int?
  totalHealingDone             Int?
  totalDamageDealtToStructures Int?
  totalDamageDealtToObjectives Int?
  largestCriticalStrike        Int?
  laneMinionsKilled            Int?
  goldSpent                    Int?
  largestKillingSpree          Int?
  multiKill                    Int?
  physicalDamageDealt          Int?
  magicalDamageDealt           Int?
  trueDamageDealt              Int?

  @@unique([matchId, playerId])
}

// ── Event stream models ───────────────────────────────────────────────────────

model HeroKill {
  id             String  @id @default(cuid())
  matchId        String
  match          Match   @relation(fields: [matchId], references: [id])
  gameTime       Int
  locationX      Float?
  locationY      Float?
  locationZ      Float?
  killerTeam     String?
  killedTeam     String?
  killerHeroSlug String?
  killedHeroSlug String?
  killerPlayerId String?
  killedPlayerId String?
}

model ObjectiveKill {
  id           String  @id @default(cuid())
  matchId      String
  match        Match   @relation(fields: [matchId], references: [id])
  gameTime     Int
  entityType   String
  killerTeam   String?
  killerPlayerId String?
  locationX    Float?
  locationY    Float?
  locationZ    Float?
}

model StructureDestruction {
  id              String  @id @default(cuid())
  matchId         String
  match           Match   @relation(fields: [matchId], references: [id])
  gameTime        Int
  structureType   String
  destructionTeam String?
  locationX       Float?
  locationY       Float?
  locationZ       Float?
}

model WardEvent {
  id        String  @id @default(cuid())
  matchId   String
  match     Match   @relation(fields: [matchId], references: [id])
  gameTime  Int
  eventType String
  wardType  String
  locationX Float?
  locationY Float?
  locationZ Float?
  playerId  String?
  team      String?
}

model Transaction {
  id              String  @id @default(cuid())
  matchId         String
  match           Match   @relation(fields: [matchId], references: [id])
  gameTime        Int
  transactionType String
  itemName        String?
  playerId        String?
  team            String?
}

model HeroBan {
  id       String @id @default(cuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id])
  heroSlug String
  team     String
}

model SyncLog {
  id        String   @id @default(cuid())
  entity    String
  entityId  String
  operation String
  status    String
  syncedAt  DateTime @default(now())
  error     String?
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  globalRole   String   @default("VIEWER") // PLATFORM_ADMIN | VIEWER
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  lastLoginAt  DateTime?

  memberships     TeamMembership[]
  sentInvitations Invitation[] @relation("InvitedBy")
}

model TeamMembership {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  teamId   String
  team     Team    @relation(fields: [teamId], references: [id])
  role     String  // MANAGER | COACH | ANALISTA | JUGADOR
  playerId String? // FK a Player si role = JUGADOR

  @@unique([userId, teamId])
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  email       String
  teamId      String
  role        String    // MANAGER | COACH | ANALISTA | JUGADOR
  invitedById String
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
}
