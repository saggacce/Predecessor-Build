generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Version {
  id          String           @id @default(cuid())
  predggId    String           @unique
  name        String
  releaseDate DateTime
  patchType   String
  syncedAt    DateTime
  matches     Match[]
  snapshots   PlayerSnapshot[]
}

model Player {
  id             String           @id @default(cuid())
  predggId       String           @unique
  predggUuid     String           @unique
  displayName    String
  isPrivate      Boolean          @default(false)
  inferredRegion String?
  firstSeen      DateTime         @default(now())
  lastSynced     DateTime
  customName     String?
  isConsole      Boolean          @default(false)
  matchPlayers   MatchPlayer[]
  snapshots      PlayerSnapshot[]
  rosterEntries  TeamRoster[]
  userAccount    User?
}

model PlayerSnapshot {
  id           String   @id @default(cuid())
  playerId     String
  versionId    String?
  syncedAt     DateTime
  generalStats Json
  heroStats    Json
  roleStats    Json
  rankLabel    String?
  ratingPoints Int?
  player       Player   @relation(fields: [playerId], references: [id])
  version      Version? @relation(fields: [versionId], references: [id])
}

model Team {
  id                String           @id @default(cuid())
  name              String
  abbreviation      String?
  type              TeamType
  region            String?
  notes             String?
  createdAt         DateTime         @default(now())
  logoUrl           String?
  teamTier          String           @default("FREE")
  teamTierExpiresAt DateTime?
  llmAnalyses       LlmAnalysis[]
  memberships       TeamMembership[]
  roster            TeamRoster[]
}

model TeamRoster {
  id         String    @id @default(cuid())
  teamId     String
  playerId   String
  role       String?
  activeFrom DateTime  @default(now())
  activeTo   DateTime?
  player     Player    @relation(fields: [playerId], references: [id])
  team       Team      @relation(fields: [teamId], references: [id])
}

model Match {
  id                    String                 @id @default(cuid())
  predggUuid            String                 @unique
  startTime             DateTime
  duration              Int
  gameMode              String
  region                String?
  winningTeam           String?
  versionId             String?
  syncedAt              DateTime
  eventStreamFailed     Boolean                @default(false)
  eventStreamSynced     Boolean                @default(false)
  rosterSynced          Boolean                @default(false)
  heroBans              HeroBan[]
  heroKills             HeroKill[]
  version               Version?               @relation(fields: [versionId], references: [id])
  matchPlayers          MatchPlayer[]
  objectiveKills        ObjectiveKill[]
  structureDestructions StructureDestruction[]
  transactions          Transaction[]
  wardEvents            WardEvent[]
}

model MatchPlayer {
  id                           String  @id @default(cuid())
  matchId                      String
  playerId                     String?
  playerName                   String
  team                         String
  role                         String?
  heroSlug                     String
  kills                        Int
  deaths                       Int
  assists                      Int
  heroDamage                   Int?
  totalDamage                  Int?
  gold                         Int?
  wardsPlaced                  Int?
  inventoryItems               Json
  perkSlug                     String?
  perks                        Json?
  abilityOrder                 Json?
  predggPlayerUuid             String?
  level                        Int?
  wardsDestroyed               Int?
  goldEarnedAtInterval         Json?
  goldSpent                    Int?
  heroDamageTaken              Int?
  laneMinionsKilled            Int?
  largestCriticalStrike        Int?
  largestKillingSpree          Int?
  magicalDamageDealt           Int?
  magicalDamageDealtToHeroes   Int?
  multiKill                    Int?
  physicalDamageDealt          Int?
  physicalDamageDealtToHeroes  Int?
  totalDamageDealtToObjectives Int?
  totalDamageDealtToStructures Int?
  totalDamageTaken             Int?
  totalHealingDone             Int?
  trueDamageDealt              Int?
  trueDamageDealtToHeroes      Int?
  match                        Match   @relation(fields: [matchId], references: [id])
  player                       Player? @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId])
}

model HeroKill {
  id             String   @id @default(cuid())
  matchId        String
  gameTime       Int
  syncedAt       DateTime @default(now())
  locationX      Float?
  locationY      Float?
  locationZ      Float?
  killerTeam     String?
  killedTeam     String?
  killerHeroSlug String?
  killedHeroSlug String?
  killerPlayerId String?
  killedPlayerId String?
  match          Match    @relation(fields: [matchId], references: [id])
}

model ObjectiveKill {
  id             String   @id @default(cuid())
  matchId        String
  gameTime       Int
  syncedAt       DateTime @default(now())
  entityType     String
  killerTeam     String?
  killerPlayerId String?
  locationX      Float?
  locationY      Float?
  locationZ      Float?
  match          Match    @relation(fields: [matchId], references: [id])
}

model StructureDestruction {
  id              String   @id @default(cuid())
  matchId         String
  gameTime        Int
  syncedAt        DateTime @default(now())
  structureType   String
  destructionTeam String?
  locationX       Float?
  locationY       Float?
  locationZ       Float?
  match           Match    @relation(fields: [matchId], references: [id])
}

model WardEvent {
  id        String   @id @default(cuid())
  matchId   String
  gameTime  Int
  syncedAt  DateTime @default(now())
  eventType String
  wardType  String
  locationX Float?
  locationY Float?
  locationZ Float?
  playerId  String?
  team      String?
  match     Match    @relation(fields: [matchId], references: [id])
}

model Transaction {
  id              String   @id @default(cuid())
  matchId         String
  gameTime        Int
  syncedAt        DateTime @default(now())
  transactionType String
  itemName        String?
  playerId        String?
  team            String?
  match           Match    @relation(fields: [matchId], references: [id])
}

model HeroBan {
  id       String @id @default(cuid())
  matchId  String
  heroSlug String
  team     String
  match    Match  @relation(fields: [matchId], references: [id])
}

model MapZone {
  id               String  @id @default(cuid())
  key              String  @unique
  name             String
  polygon          Json
  zoneType         String
  relatedObjective String?
}

model SyncLog {
  id        String   @id @default(cuid())
  entity    String
  entityId  String
  operation String
  status    String
  syncedAt  DateTime @default(now())
  error     String?
  source    String?
  userName  String?
}

model User {
  id                  String           @id @default(cuid())
  email               String           @unique
  name                String
  passwordHash        String
  globalRole          String           @default("VIEWER")
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  lastLoginAt         DateTime?
  avatarUrl           String?
  bio                 String?
  timezone            String?
  linkedPlayerId      String?          @unique
  playerTier          String           @default("FREE")
  playerTierExpiresAt DateTime?
  discordId           String?          @unique
  discordUsername     String?
  epicGamesId         String?          @unique
  epicGamesUsername   String?
  steamId             String?          @unique
  steamUsername       String?
  sentInvitations     Invitation[]     @relation("InvitedBy")
  memberships         TeamMembership[]
  linkedPlayer        Player?          @relation(fields: [linkedPlayerId], references: [id])
}

model TeamMembership {
  id       String  @id @default(cuid())
  userId   String
  teamId   String
  role     String
  playerId String?
  team     Team    @relation(fields: [teamId], references: [id])
  user     User    @relation(fields: [userId], references: [id])

  @@unique([userId, teamId])
}

model Invitation {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  email       String
  teamId      String
  role        String
  playerId    String?
  invitedById String
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())
  invitedBy   User      @relation("InvitedBy", fields: [invitedById], references: [id])
}

model ReviewItem {
  id           String   @id @default(cuid())
  teamId       String
  matchId      String?
  playerId     String?
  insightId    String?
  gameTime     Int?
  eventType    String
  priority     String   @default("high")
  reason       String
  status       String   @default("PENDING")
  tag          String?
  coachComment String?
  assignedTo   String?
  actionItem   String?
  vodUrl       String?
  vodTimestamp Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TeamGoal {
  id            String   @id @default(cuid())
  teamId        String
  title         String
  description   String?
  metricId      String?
  baselineValue Float?
  targetValue   Float?
  currentValue  Float?
  timeframe     String?
  priority      String   @default("medium")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PlayerGoal {
  id            String   @id @default(cuid())
  playerId      String
  teamId        String
  title         String
  description   String?
  metricId      String?
  baselineValue Float?
  targetValue   Float?
  currentValue  Float?
  coachNote     String?
  visibility    String   @default("staff")
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LlmAnalysis {
  id           String   @id @default(cuid())
  teamId       String
  model        String
  insightsJson Json
  outputText   String
  promptTokens Int?
  outputTokens Int?
  feedback     String?
  correction   String?
  createdAt    DateTime @default(now())
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model PlatformCredential {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model PlatformConfig {
  key          String   @id
  value        Float
  defaultValue Float
  minValue     Float?
  maxValue     Float?
  label        String
  description  String
  group        String
  unit         String?
  updatedAt    DateTime @updatedAt
  updatedBy    String?
}

model HeroMeta {
  id          String   @id @default(cuid())
  slug        String   @unique
  displayName String
  classes     Json
  roles       Json
  imageUrl    String?
  abilities   Json?
  baseStats   Json?
  syncedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VodLink {
  id                  String   @id @default(cuid())
  matchId             String?
  playerId            String?
  teamId              String
  type                String
  url                 String
  gameTimeStart       Int?
  gameTimeEnd         Int?
  videoTimestampStart Int?
  videoTimestampEnd   Int?
  tags                String[] @default([])
  notes               String?
  visibility          String   @default("staff")
  createdAt           DateTime @default(now())
}

model FeedbackReport {
  id               String    @id @default(cuid())
  type             String
  section          String
  description      String
  screenshotBase64 String?
  status           String    @default("NEW")
  userId           String?
  userName         String?
  userEmail        String?
  createdAt        DateTime  @default(now())
  reviewedAt       DateTime?
  reviewNote       String?
}

enum TeamType {
  OWN
  RIVAL
}

model PermissionsConfig {
  id          String   @id @default("global")
  permissions Json
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}
